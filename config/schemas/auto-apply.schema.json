{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auto-apply.schema.json",
  "type": "object",
  "required": ["schema_version", "configured_mode", "human_review_required"],
  "properties": {
    "schema_version": { "const": 1 },
    "configured_mode": { "type": "string", "enum": ["manual", "supervised_auto"] },
    "human_review_required": { "const": true }
  },
  "additionalProperties": false
}
