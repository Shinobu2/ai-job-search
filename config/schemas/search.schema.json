{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "search.schema.json",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "const": 1 },
    "discovery": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "enabled", "mode", "country", "cities", "keywords", "max_pages", "page_size"],
            "properties": {
              "id": { "enum": ["freehire", "jobsuche"] },
              "enabled": { "type": "boolean" },
              "mode": { "const": "read_import_evaluate" },
              "country": { "const": "DE" },
              "cities": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string", "minLength": 1 } },
              "keywords": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "minLength": 1 } },
              "max_pages": { "type": "integer", "minimum": 1, "maximum": 3 },
              "page_size": { "type": "integer", "minimum": 1, "maximum": 25 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
