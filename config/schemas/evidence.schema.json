{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "type": "object",
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": { "const": 1 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "statement", "reviewer_status", "provenance"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["hardware", "networking", "informal_assistance", "planned_project"] },
          "statement": { "type": "string", "minLength": 1 },
          "reviewer_status": { "type": "string", "enum": ["unreviewed", "UNKNOWN"] },
          "provenance": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/provenance" } }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "planned_project" } } },
            "then": {
              "not": {
                "properties": {
                  "statement": { "type": "string", "pattern": "\\b[Cc][Oo][Mm][Pp][Ll][Ee][Tt][Ee][Dd]\\b|\\b[Ee][Mm][Pp][Ll][Oo][Yy][Mm][Ee][Nn][Tt]\\b" }
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "informal_assistance" } } },
            "then": {
              "not": {
                "properties": {
                  "statement": { "type": "string", "pattern": "\\b[Pp][Rr][Oo][Ff][Ee][Ss][Ss][Ii][Oo][Nn][Aa][Ll]\\b" }
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "planned_project" } } },
            "then": { "properties": { "reviewer_status": { "const": "UNKNOWN" } } }
          },
          {
            "if": {
              "properties": {
                "kind": { "enum": ["hardware", "networking", "informal_assistance"] }
              }
            },
            "then": { "properties": { "reviewer_status": { "const": "unreviewed" } } }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
